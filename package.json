{
  "name": "opr-card-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Standard TCG Card Generator for OnePageRules",
  "license": "SEE LICENSE IN LICENSE",
  "scripts": {
    "start": "parcel index.html",
    "build": "parcel build index.html --dist-dir docs --public-url ./",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc --noEmit --project netlify/tsconfig.json",
    "api": "yarn --cwd api dev",
    "dev": "concurrently -n api,web -c blue,magenta \"yarn api\" \"yarn start\""
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "buffer": "^5.5.0||^6.0.0",
    "concurrently": "^8.2.2",
    "parcel": "^2.12.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "localbase": "^0.7.7"
  }
}
